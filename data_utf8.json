      2
    ]
  }
},
{
  "model": "app.projet",
  "pk": 2,
  "fields": {
    "name": "SOS Alerte / AlertSapeur",
    "description": "Application mobile d'alerte citoyenne permettant de signaler des incidents en temps réel aux services de secours avec géolocalisation précise.",
    "long_description": "Développée pour réduire les délais d'intervention des secours, cette application permet à un témoin d'envoyer une alerte enrichie en quelques secondes. Le système capture automatiquement les coordonnées GPS et permet l'envoi de flux médias (photos et vidéos) pour aider les opérateurs à évaluer la gravité de la situation avant l'arrivée sur les lieux. Le backend assure une distribution intelligente des alertes vers les centres de secours les plus proches.",
    "image": "projets/2026-06-11_2.png",
    "github_link": "https://www.github.com",
    "demo_link": null,
    "date_created": "2026-04-10",
    "views_count": 0,
