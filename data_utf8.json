{
  "model": "app.projet",
  "pk": 1,
  "fields": {
    "name": "DiploChaineRecruteur",
    "description": "Plateforme de sécurisation et de vérification de diplômes universitaires via QR codes et empreintes numériques.",
    "long_description": "e projet répond au problème de la falsification de documents académiques. Il permet aux institutions d'importer leurs propres modèles de diplômes (PDF) et de générer des certificats uniques. Chaque document est associé à un hachage cryptographique unique et un QR Code. Un recruteur peut scanner ce code pour vérifier instantanément l'authenticité du diplôme sur la plateforme, garantissant ainsi l'intégrité des données sans intervention manuelle de l'université.",
    "image": "projets/Capture_décran_2026-02-24_113606.png",
    "github_link": "https://www.thesvg.org/",
    "demo_link": null,
    "date_created": "2026-05-16",
